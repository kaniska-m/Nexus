# ================================================
# Nexus — Environment Configuration
# Copy this file to .env and fill in your values
# ================================================

# === Groq API (Free Tier — 30 req/min) ===
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# === LLM Model Routing ===
# Heavy tasks: compliance checklists, risk scoring, fraud analysis
LLM_MODEL_HEAVY=llama-3.1-8b-instant
# Light tasks: reminders, summaries, form validation
LLM_MODEL_LIGHT=llama-3.1-8b-instant
# Temperature settings
LLM_TEMPERATURE_HEAVY=0.3
LLM_TEMPERATURE_LIGHT=0.5

# === FastAPI Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === Application ===
APP_NAME=Nexus
APP_ENV=development
LOG_LEVEL=INFO

# === File Storage (uploads) ===
UPLOAD_DIR=./uploads
AUDIT_PDF_DIR=./audit_reports
